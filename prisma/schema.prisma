// GradOps — Recent Graduate–Only Job Search Platform
// https://github.com/gradops

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum JobSourceType {
  EMPLOYER_POST
  LEVER
  GREENHOUSE
  GOV_PORTAL
  LICENSED_FEED
  COMPANY_CAREERS
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  INTERESTED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum InterestStatus {
  PENDING
  SHORTLISTED
  REJECTED
}

enum TakedownStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         UserRole
  emailVerified DateTime? @map("email_verified")
  image        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  jobSeekerProfile JobSeekerProfile?
  employerProfile  EmployerProfile?
  savedJobs        SavedJob[]
  savedSearches    SavedSearch[]
  jobAlerts        JobAlert[]
  applicationTracker ApplicationTracker[]
  breakReminderSettings BreakReminderSettings?
  breakReminderState    BreakReminderState?
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model JobSeekerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  name              String?
  country           String?
  city              String?
  graduationDate    DateTime? @map("graduation_date")
  degree            String?
  major             String?
  skills            String[]  @default([])
  workAuthorization String?   @map("work_authorization")
  visaNeeds         String?   @map("visa_needs")
  resumeUrl         String?   @map("resume_url")
  resumeDeletedAt   DateTime? @map("resume_deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  employerInterests EmployerJobInterest[]
}

model EmployerProfile {
  id            String    @id @default(cuid())
  userId        String    @unique @map("user_id")
  companyName   String    @map("company_name")
  website       String?
  industry      String?
  size          String?
  hqCountry     String?   @map("hq_country")
  verifiedDomain String?  @map("verified_domain")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]
}

model Job {
  id              String         @id @default(cuid())
  employerId      String?        @map("employer_id")
  sourceType      JobSourceType  @map("source_type")
  sourceName      String         @map("source_name")
  sourceUrl       String?        @map("source_url") @db.Text
  canonicalUrl    String         @map("canonical_url") @db.Text
  externalId     String?        @map("external_id")
  title           String
  companyName     String         @map("company_name")
  country         String
  location        String?
  remoteType      RemoteType     @map("remote_type")
  jobType         JobType        @map("job_type")
  salaryMin       Int?           @map("salary_min")
  salaryMax       Int?           @map("salary_max")
  salaryCurrency  String?        @map("salary_currency")
  description     String         @db.Text
  requiredSkills  String[]       @default([]) @map("required_skills")
  preferredSkills String[]       @default([]) @map("preferred_skills")
  experienceMin   Int?           @map("experience_min")
  experienceMax   Int?           @map("experience_max")
  recentGradEligible Boolean     @default(true) @map("recent_grad_eligible")
  visaSponsorship Boolean        @default(false) @map("visa_sponsorship")
  industry        String?
  status          String         @default("published")
  postedAt        DateTime       @map("posted_at")
  expiresAt       DateTime?      @map("expires_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  contentHash     String?        @map("content_hash")

  employer        EmployerProfile?   @relation(fields: [employerId], references: [id], onDelete: SetNull)
  recentGradScore JobRecentGradScore?
  tags            JobTag[]
  savedJobs       SavedJob[]
  applications    ApplicationTracker[]
  interests       EmployerJobInterest[]
  takedownRequests TakedownRequest[]
}

model JobRecentGradScore {
  id          String   @id @default(cuid())
  jobId       String   @unique @map("job_id")
  score       Int
  reasons     Json     @default("[]")
  modelVersion String? @map("model_version")
  createdAt   DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobTag {
  id    String @id @default(cuid())
  jobId String @map("job_id")
  name  String
  type  String @default("function")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  @@unique([jobId, name])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  @@unique([userId, jobId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String?
  filters   Json
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobAlert {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  cadence   String
  filters   Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApplicationTracker {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  jobId     String            @map("job_id")
  status    ApplicationStatus
  notes     String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  @@unique([userId, jobId])
}

model EmployerJobInterest {
  id        String         @id @default(cuid())
  jobId     String         @map("job_id")
  seekerId  String         @map("seeker_id")
  message   String?        @db.Text
  status    InterestStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")

  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker JobSeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)
  @@unique([jobId, seekerId])
}

model TakedownRequest {
  id             String        @id @default(cuid())
  jobId          String        @map("job_id")
  requesterEmail String        @map("requester_email")
  reason         String        @db.Text
  status         TakedownStatus @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at")
  resolvedAt     DateTime?     @map("resolved_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model BreakReminderSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  enabled             Boolean  @default(false)
  intervalMinutes     Int      @default(45) @map("interval_minutes")
  quietHoursStart     Int?     @map("quiet_hours_start")
  quietHoursEnd       Int?     @map("quiet_hours_end")
  message             String?  @db.Text
  idleThresholdMinutes Int     @default(5) @map("idle_threshold_minutes")
  snoozeMinutesDefault Int     @default(10) @map("snooze_minutes_default")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BreakReminderState {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  lastNotifiedAt DateTime? @map("last_notified_at")
  snoozedUntil   DateTime? @map("snoozed_until")
  pausedUntil    DateTime? @map("paused_until")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
